{
  "name": "mbox-viewer",
  "version": "1.0.0",
  "description": "mbox file viewer for macOS",
  "main": "dist/main.js",
  "scripts": {
    "compile": "tsc && npm run bundle-renderer",
    "bundle-renderer": "esbuild src/renderer/index.tsx --bundle --outfile=dist/renderer.js --platform=browser --jsx=automatic",
    "test": "jest",
    "start": "npm run compile && electron .",
    "build": "npm run compile && electron-builder --publish never",
    "build:mac": "npm run build -- --mac dmg --universal",
    "build:win": "npm run build -- --win nsis --x64",
    "build:linux": "npm run build -- --linux AppImage --x64"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.mailark.app",
    "productName": "mailark",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
